// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Base de données robuste pour le e-commerce
  url      = env("DATABASE_URL")
}

// 1. Définition stricte des rôles (Cybersécurité & Accès)
enum Role {
  GUEST
  CLIENT
  MANAGER
  ADMIN
}

// 2. Utilisateurs (Clients, Managers, Admins)
model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  role           Role     @default(GUEST)
  createdAt      DateTime @default(now())

  isEmailVerified         Boolean   @default(false)
  emailVerificationToken  String?
  emailVerificationExpiry DateTime?
  passwordResetToken      String?
  passwordResetExpiry     DateTime?

  stripeCustomerId String?

  managedStoreId String?
  managedStore   Store?   @relation("StoreManagers", fields: [managedStoreId], references: [id])

  orders        Order[]
  subscriptions Subscription[]
}

// 3. Boutiques (Magasins physiques pour le Click & Collect)
model Store {
  id        String   @id @default(uuid())
  name      String
  address   String
  isActive  Boolean  @default(true)

  managers        User[]          @relation("StoreManagers")
  products        Product[]
  orders          Order[]
  subscriptions   Subscription[]
  managerInvites  ManagerInvite[]
}

// 7. Codes d'invitation manager (générés par l'admin)
model ManagerInvite {
  id        String    @id @default(uuid())
  code      String    @unique
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id])
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime?
}

// 4. Produits (Fruits découpés, Smoothies)
model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  isAvailable Boolean  @default(true)

  storeId           String
  store             Store              @relation(fields: [storeId], references: [id])
  orderItems        OrderItem[]
  subscriptionItems SubscriptionItem[]
}

// 5. Commandes (Achat ponctuel ou Abonnement)
model Order {
  id          String      @id @default(uuid())
  totalAmount Float
  status      String      @default("PENDING") // PENDING, ACCEPTED, READY, CANCELLED
  pickupDate  DateTime
  isRecurring Boolean     @default(false)

  userId      String?
  user        User?        @relation(fields: [userId], references: [id])
  storeId     String
  store       Store        @relation(fields: [storeId], references: [id])
  items       OrderItem[]

  guestEmail  String?
  guestPhone  String?

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  createdAt   DateTime    @default(now())
}

// 8. Abonnements récurrents
model Subscription {
  id                   String                 @id @default(uuid())
  userId               String
  user                 User                   @relation(fields: [userId], references: [id])
  storeId              String
  store                Store                  @relation(fields: [storeId], references: [id])
  status               String                 @default("ACTIVE") // ACTIVE, PAUSED, CANCELLED
  monthlyAmount        Float
  discountPercent      Float                  @default(15)
  stripeSubscriptionId String?                @unique
  stripeCustomerId     String?
  items                SubscriptionItem[]
  schedules            SubscriptionSchedule[]
  orders               Order[]
  createdAt            DateTime               @default(now())
}

model SubscriptionItem {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  quantity       Int
  unitPrice      Float
}

model SubscriptionSchedule {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  pickupTime     String
}

// 6. Lignes de commande (détail du panier)
model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Float

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])
}